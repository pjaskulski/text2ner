digraph text2ner_process_simple {
    graph [
        rankdir=TB,
        labelloc="t",
        label="TEXT2NER: uproszczony przebieg pracy aplikacji",
        fontsize=20,
        fontname="Helvetica",
        pad=0.3,
        nodesep=0.45,
        ranksep=0.75,
        splines=polyline,
        bgcolor="white"
    ];

    node [
        shape=box,
        style="rounded,filled",
        fillcolor="#F8FAFC",
        color="#94A3B8",
        fontname="Helvetica",
        fontsize=12,
        margin="0.18,0.12"
    ];

    edge [
        color="#475569",
        arrowsize=0.8,
        fontname="Helvetica",
        fontsize=10
    ];

    start [label="1. Dokument do analizy wprowadzony do pola tekstowego (do 5000 znaków)", fillcolor="#E0F2FE", color="#0284C7"];
    settings [label="2. Parametry analizy:\nmodel Gemini oraz typy tagów,\nktóre mają być rozpoznawane"];
    recognize [label="3. Funkcja Rozpoznaj encje\nAplikacja tworzy TEI-XML\ni oznacza osoby, miejsca,\ndaty, funkcje i instytucje (tagi zależnie od ustawień)"];
    preview [label="4. Podgląd wyniku\nUżytkownik ogląda XML\nlub kolorowany podgląd tekstu"];
    manual [label="5. Opcjonalna korekta ręczna\nMożna usunąć tag,\nzmienić jego typ albo dodać nowy"];
    pdf_before [label="6. Eksport PDF podglądu\nMożna pobrać kolorowy podgląd\naktualnego tekstu i oznaczeń", fillcolor="#FEF3C7", color="#D97706"];
    identify [label="7. Identyfikacja encji jako zadanie w tle\nAplikacja przyjmuje XML do kolejki\ni pokazuje pasek postępu"];
    sources [label="8. Wyszukiwanie kandydatów\nw WikiHum, va.wiki.kul.pl,\njeżeli nieskuteczna -> Wikidata\noraz polska i angielska Wikipedia"];
    decision [label="9. Ocena kandydatów\nModel Gemini porównuje kontekst,\nwarianty nazwy (dla osób\nrównież zgodność chronologiczną)"];
    result [label="10. Wynik końcowy\nTEI-XML z wyróżnieniem osób, miejsc i ich identyfikacją", fillcolor="#DCFCE7", color="#16A34A"];
    lists [label="11. Dodatkowe wyniki:\nLista encji (osób i miejsc) zidentyfikowanych\ni niezidentyfikowanych"];
    pdf_after [label="12. Eksport PDF po identyfikacji\nPodgląd zawiera także listy encji"];
    log [label="13. Log diagnostyczny\nMożna pobrać pełny log\nlub obejrzeć fragment\ndla konkretnej encji", fillcolor="#FEF3C7", color="#D97706"];

    start -> settings -> recognize -> preview -> manual -> pdf_before -> identify -> sources -> decision -> result -> lists -> pdf_after -> log;
    preview -> identify [label="jeśli nie ma korekty"];
    preview -> pdf_before [label="PDF bez identyfikacji"];
}
