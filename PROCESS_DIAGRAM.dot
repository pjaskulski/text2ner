digraph text2ner_process {
    graph [
        rankdir=TB,
        labelloc="t",
        label="TEXT2NER: proces rozpoznawania i identyfikacji encji w TEI-XML",
        fontsize=20,
        fontname="Helvetica",
        pad=0.3,
        nodesep=0.35,
        ranksep=0.65,
        splines=polyline,
        bgcolor="white"
    ];

    node [
        shape=box,
        style="rounded,filled",
        fillcolor="#F8FAFC",
        color="#94A3B8",
        fontname="Helvetica",
        fontsize=11,
        margin="0.16,0.10"
    ];

    edge [
        color="#475569",
        arrowsize=0.7,
        fontname="Helvetica",
        fontsize=10
    ];

    start [label="Użytkownik wkleja tekst\nw aplikacji WWW", fillcolor="#E0F2FE", color="#0284C7"];
    settings [label="Parametry analizy:\nwybór modelu Gemini\noraz typów tagów\n(persName, placeName, date,\nroleName, orgName)"];
    subgraph cluster_recognize {
        label="1. Etap rozpoznawania encji";
        color="#CBD5E1";
        style="rounded";

        post_recognize [label="POST /recognize"];
        start_log_rec [label="start_diagnostic_session:\nusuń logi starsze niż 48 h\nutwórz nowy plik logu"];
        recognize_request [label="Walidacja żądania:\ntext <= 5000 znaków\ntag_types\nmodel_name"];
        tagging_prompt [label="Budowa promptu NER\nwg włączonych tagów"];
        gemini_first_pass [label="Gemini:\npierwszy pass tagowania XML"];
        gemini_review_pass [label="Gemini:\ndrugi pass korekcyjny\n(review tagged XML)"];
        review_success [shape=diamond, label="Czy drugi pass\nzakończył się powodzeniem?"];
        raw_tagged_xml [label="XML roboczy z tagami\npersName, placeName,\ndate, roleName, orgName"];
        normalize_tei [label="BeautifulSoup + compress_inline_tags\n+ serialize_inner_xml"];
        tei_without_ids [label="Pełny TEI-XML\nbez identyfikacji referencyjnej", fillcolor="#DCFCE7", color="#16A34A"];
        recognize_response [label="JSON /recognize:\nxml\nrecognized_tag_types\nidentification_performed=false\ndiagnostic_log_file", fillcolor="#E0F2FE", color="#0284C7"];
    }

    subgraph cluster_review {
        label="2. Praca użytkownika po rozpoznaniu";
        color="#CBD5E1";
        style="rounded";

        preview_xml [label="Widok XML oraz podgląd tekstu\nz kolorowaniem tagów"];
        manual_edit [label="Opcjonalna korekta ręczna:\nusuń tag / zmień typ / dodaj tag"];
        run_identify [shape=diamond, label="Czy uruchomić\nIdentyfikuj encje?"];
        keep_only_tei [label="Koniec po etapie 1:\nTEI-XML z tagami,\nbez ref dla persName/placeName", fillcolor="#E0F2FE", color="#0284C7"];
    }

    subgraph cluster_identify {
        label="3. Etap identyfikacji encji";
        color="#CBD5E1";
        style="rounded";

        post_identify [label="POST /identify"];
        start_log_identify [label="start_diagnostic_session:\nusuń logi starsze niż 48 h\nutwórz nowy plik logu"];
        identify_input [label="Identyfikacja w istniejącym TEI:\nextract_inner_xml\n+ model_name"];
        extract_doc_years [label="Wykrycie lat dokumentu\nz całego XML / tekstu"];
        entity_loop [label="Pętla po tagach\npersName i placeName"];
        entity_context [label="Pobranie surface form\ni kontekstu encji"];
        cache_check [shape=diamond, label="Czy encja została już\nskutecznie rozstrzygnięta\nw tym dokumencie?"];
        cache_hit [label="Użycie wyniku z cache\n(key/ref bez ponownej analizy)"];
        link_entity [label="link_entity(...)", fillcolor="#F1F5F9", color="#64748B"];

        analyze_form [label="Gemini:\nanalyze_form_with_gemini"];
        analyze_outputs [label="normalized_best\nlemma_candidates\nsurface_variants\noffice_terms\nplace_terms\ncontext_clues\ncontext_years"];
        build_plan [label="build_query_plan"];

        specialized_search [label="Special:Search ~2\nw WikiHum i va.wiki.kul.pl"];
        specialized_filter [label="Filtrowanie po typie\npersName / placeName\n+ deduplikacja i ranking"];
        specialized_decision [label="Gemini:\nbuild_link_decision\n(selected_url, reason,\nmatched_signals)"];
        specialized_selected [shape=diamond, label="Czy wybrano kandydata\nze źródeł specjalistycznych?"];

        wikidata_retry [label="Ponowna próba:\nSpecial:Search ~2\nwyłącznie w Wikidata"];
        wikidata_filter [label="Filtrowanie po typie\n+ deduplikacja i ranking"];
        wikidata_decision [label="Gemini:\nbuild_link_decision"];
        wikidata_selected [shape=diamond, label="Czy wybrano kandydata\nz Wikidaty?"];

        plwiki_check [shape=diamond, label="Czy uruchomić\nfallback plwiki?\n(tylko część persName)"];
        plwiki_search [label="plwiki search API\n+ pageprops + extract"];
        plwiki_to_wikidata [label="Konwersja do kandydatów\nWikidata z leadem"];
        plwiki_decision [label="Gemini:\nbuild_link_decision"];
        selected_final [shape=diamond, label="Czy wybrano\nkandydata?"];
    }

    subgraph cluster_finish {
        label="4. Zapis wyniku i odpowiedź";
        color="#CBD5E1";
        style="rounded";

        resolved [label="Ustawienie key + ref\noraz dopisanie do entities", fillcolor="#DCFCE7", color="#16A34A"];
        unresolved [label="Ustawienie tylko key\noraz dopisanie do unresolved_entities", fillcolor="#FEF3C7", color="#D97706"];
        next_entity [shape=diamond, label="Czy są kolejne\nencje do identyfikacji?"];
        build_final_tei [label="serialize_inner_xml\n+ build_full_tei_xml"];
        sort_outputs [label="Sortowanie lists:\nentities\nunresolved_entities"];
        identify_response [label="JSON /identify:\nxml\nentities\nunresolved_entities\nidentification_performed=true\ndiagnostic_log_file", fillcolor="#E0F2FE", color="#0284C7"];
        ui_output [label="UI: kod XML, podgląd tekstu,\nlista encji, przyciski logu,\npobieranie XML/logu", fillcolor="#E0F2FE", color="#0284C7"];
    }

    start -> settings;
    settings -> post_recognize [label="standardowy workflow"];

    post_recognize -> start_log_rec -> recognize_request -> tagging_prompt -> gemini_first_pass -> gemini_review_pass -> review_success;
    review_success -> raw_tagged_xml [label="nie,\nzostaje 1. pass"];
    review_success -> raw_tagged_xml [label="tak,\nużyj wyniku review"];
    raw_tagged_xml -> normalize_tei -> tei_without_ids;

    tei_without_ids -> recognize_response [label="/recognize"];
    recognize_response -> preview_xml -> manual_edit -> run_identify;
    run_identify -> keep_only_tei [label="nie"];
    run_identify -> post_identify [label="tak"];

    post_identify -> start_log_identify -> identify_input;
    tei_without_ids -> identify_input [label="XML po rozpoznaniu"];

    identify_input -> extract_doc_years -> entity_loop -> entity_context -> cache_check;
    cache_check -> cache_hit [label="tak"];
    cache_check -> link_entity [label="nie"];

    link_entity -> analyze_form -> analyze_outputs -> build_plan -> specialized_search -> specialized_filter -> specialized_decision -> specialized_selected;
    specialized_selected -> resolved [label="tak"];
    specialized_selected -> wikidata_retry [label="nie"];

    wikidata_retry -> wikidata_filter -> wikidata_decision -> wikidata_selected;
    wikidata_selected -> resolved [label="tak"];
    wikidata_selected -> plwiki_check [label="nie"];

    plwiki_check -> unresolved [label="nie"];
    plwiki_check -> plwiki_search [label="tak"];
    plwiki_search -> plwiki_to_wikidata -> plwiki_decision -> selected_final;
    selected_final -> resolved [label="tak"];
    selected_final -> unresolved [label="nie"];

    cache_hit -> next_entity;
    resolved -> next_entity;
    unresolved -> next_entity;
    next_entity -> entity_loop [label="tak"];
    next_entity -> build_final_tei [label="nie"];

    build_final_tei -> sort_outputs -> identify_response -> ui_output;
}
